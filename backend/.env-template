# --- Gradium TTS (Existing) ---
GRADIUM_API_KEY=your_gradium_api_key_here
GRADIUM_VOICE_ID=OceLYI_PPbqsdgdV
GRADIUM_API_REGION=us

# --- Shared Backend API Security ---
# Required for the FastAPI backend and the PDF Lambda/dev server.
# Any client calling protected endpoints must send this value in the `x-api-key` header.
APP_API_KEY=replace_with_shared_backend_api_key

# --- Local PDF Browser Override (Optional) ---
# For local Windows PDF testing only. Point this to Chrome or Edge if auto-detection does not work.
# Example: C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
CHROME_EXECUTABLE_PATH=

# --- Google Gemini (New) ---
# Get your API key from: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_gemini_api_key_here

# --- LangSmith Tracing (New) ---
# Get your API key from: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=orsushealth-dr-bear

# --- Supabase (New for Backend) ---
# Project URL: https://fpqxlyqamlhbilieuswc.supabase.co
SUPABASE_URL=https://fpqxlyqamlhbilieuswc.supabase.co
# ⚠️ NEVER share the service role key. Keep it server-side only.
# Get this from Project Settings -> API in your Supabase dashboard.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
