#
# PDF Preview Dev Tool
# Copy to `.env.local` in this folder.
#

# Required for generating PDFs in both fixture and live modes.
# Example local PDF generator: http://127.0.0.1:3001
# Example deployed PDF generator: https://abc123.lambda-url.us-east-1.on.aws
VITE_PDF_GENERATOR_URL=http://127.0.0.1:3001

# API key expected by the PDF generator Lambda / local dev server.
VITE_PDF_GENERATOR_API_KEY=replace_with_pdf_generator_api_key

# Optional: default mode shown when the app loads.
# Allowed values: fixture, live
VITE_DEFAULT_MODE=fixture

# Optional: used by live mode to call the prediction API before generating the PDF.
# Example local backend API: http://127.0.0.1:8000
# Example deployed backend API: https://abc123.lambda-url.us-east-1.on.aws
VITE_PREDICT_API_BASE_URL=http://127.0.0.1:8000

# Optional: API key expected by the prediction backend.
# If omitted, the app falls back to VITE_PDF_GENERATOR_API_KEY.
VITE_PREDICT_API_KEY=replace_with_backend_api_key
